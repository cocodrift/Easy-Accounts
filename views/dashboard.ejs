<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="topbar">
    <div class="topbar-inner container">
      <div class="brand">
        <span class="logo"></span>
        <div>
          <div class="brand-title">Easy Accounts</div>
          <div class="brand-sub muted">Dashboard</div>
        </div>
      </div>

      <div class="topbar-actions">
        <span class="chip"><%= user?.username || 'User' %></span>
        <form class="inline" method="POST" action="/auth/logout">
          <button class="btn btn-ghost" type="submit">Logout</button>
        </form>
      </div>
    </div>
  </header>

  <main class="container">
    <div class="card">
      <div class="row space-between">
        <h2>Ledger Entries</h2>
        <div class="row">
          <a class="btn" href="/ledger/add">+ Add Entry</a>
          <a class="btn" href="/ledger/income-statement">Income Statement</a>
        </div>
      </div>

      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Description</th>
              <th class="right">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% if (!entries || entries.length === 0) { %>
              <tr>
                <td colspan="4" class="muted">No entries yet. Click “Add Entry”.</td>
              </tr>
            <% } else { %>
              <% entries.forEach(e => { %>
                <tr>
                  <td><%= new Date(e.date).toLocaleString() %></td>
                  <td>
                    <span class="pill pill-<%= e.type %>"><%= e.type %></span>
                  </td>
                  <td><%= e.description %></td>
                  <td class="right"><%= Number(e.amount).toFixed(2) %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

</body>
</html>

