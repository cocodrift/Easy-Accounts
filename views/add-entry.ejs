<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Entry</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="topbar">
    <div class="topbar-inner container">
      <div class="brand">
        <span class="logo"></span>
        <div>
          <div class="brand-title">Easy Accounts</div>
          <div class="brand-sub muted">Add Entry</div>
        </div>
      </div>

      <div class="topbar-actions">
        <span class="chip"><%= user?.username || 'User' %></span>
        <a class="btn btn-ghost" href="/ledger/dashboard">Back</a>
      </div>
    </div>
  </header>

  <main class="container">
    <div class="card">
      <h2>Add Ledger Entry</h2>
      <p class="muted">Record income, expenses, purchases, or drawings.</p>

      <form class="form" method="POST" action="/ledger/add">
        <div class="grid-2">
          <div class="field">
            <label>Type</label>
            <select name="type" required>
              <option value="income">income</option>
              <option value="expense">expense</option>
              <option value="purchase">purchase</option>
              <option value="drawings">drawings</option>
            </select>
          </div>

          <div class="field">
            <label>Amount</label>
            <input name="amount" type="number" step="0.01" placeholder="e.g. 2500" required />
          </div>
        </div>

        <div class="field">
          <label>Description</label>
          <input name="description" placeholder="e.g. January sales / Rent / Stock bought" required />
        </div>

        <div class="row">
          <button class="btn btn-primary" type="submit">Save Entry</button>
          <a class="btn" href="/ledger/dashboard">Cancel</a>
        </div>
      </form>
    </div>
  </main>

</body>
</html>

